generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GcpStatus {
  pending
  creating
  active
  failed
  deleting
  delete_failed
}

enum FivetranProvisionStatus {
  pending
  provisioning
  active
  failed
}

model Organization {
  id                    String      @id @default(cuid())
  clerkOrgId            String      @unique
  gcpProjectId          String?     @unique
  gcpStatus             GcpStatus   @default(pending)
  gcpError              String?
  fivetranGroupId       String?     @unique
  fivetranDestinationId String?     @unique
  fivetranStatus        FivetranProvisionStatus @default(pending)
  fivetranError         String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  dashboards            Dashboard[]
  connections           FivetranConnection[]
}

model FivetranConnection {
  id                   String       @id @default(cuid())
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId       String
  fivetranConnectorId  String       @unique
  service              String
  schemaName           String
  syncFrequency        Int          @default(360)
  setupState           String       @default("incomplete")
  syncState            String       @default("paused")
  lastSyncAt           DateTime?
  lastErrorAt          DateTime?
  lastErrorMessage     String?
  createdByClerkUserId String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([organizationId])
}

model Dashboard {
  id             String            @id @default(cuid())
  title          String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  widgets        DashboardWidget[]
  favourites     UserFavourite[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model UserFavourite {
  id          String    @id @default(cuid())
  clerkUserId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  dashboardId String
  createdAt   DateTime  @default(now())

  @@unique([clerkUserId, dashboardId])
}

enum WidgetType {
  report
}

model DashboardWidget {
  id          String     @id @default(cuid())
  dashboard   Dashboard  @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  dashboardId String
  type        WidgetType
  config      Json
  x           Int
  y           Int
  w           Int
  h           Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
