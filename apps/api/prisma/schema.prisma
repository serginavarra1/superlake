generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GcpStatus {
  pending
  creating
  active
  failed
  deleting
  delete_failed
}

model Organization {
  id             String    @id @default(cuid())
  clerkOrgId     String    @unique
  gcpProjectId   String?   @unique
  gcpStatus      GcpStatus @default(pending)
  gcpError       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
