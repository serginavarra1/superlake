# Database
DATABASE_URL="postgresql://user:password@localhost:5432/unnamed_project?schema=public"

# Clerk
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# GCP
# GCP_PARENT_FOLDER_ID: numeric folder ID output by `terraform output tenants_folder_id`
GCP_PARENT_FOLDER_ID=xxx
GCP_BILLING_ACCOUNT_ID=XXXXXX-XXXXXX-XXXXXX
# SA emails change when you create a new base project via Terraform.
# Get the real values with: terraform output bigquery_read_sa_email / bigquery_write_sa_email
GCP_BQ_READ_SA=bigquery-read@<base_project_id>.iam.gserviceaccount.com
GCP_BQ_WRITE_SA=bigquery-write@<base_project_id>.iam.gserviceaccount.com

# Fivetran (Powered by Fivetran)
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
FIVETRAN_BASE_URL=https://api.fivetran.com
FIVETRAN_CONNECT_CARD_REDIRECT_URL=http://localhost:5173/data-management/connections/callback

# ngrok (optional — for a stable tunnel domain)
NGROK_DOMAIN=
