{
  "info": {
    "name": "Unnamed Project API",
    "_postman_id": "unnamed-project-api",
    "description": "API collection for Unnamed Project - NestJS backend with Clerk authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Public endpoint - Returns the health status of the API."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Protected endpoint - Returns the authenticated user's information from Clerk.\n\nResponse includes:\n- userId\n- sessionId\n- orgId (optional)\n- orgRole (optional)\n- orgSlug (optional)\n\nRequires a valid Clerk Bearer token in the Authorization header."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"userId\": \"user_2abc123\",\n  \"sessionId\": \"sess_2abc123\",\n  \"orgId\": \"org_2abc123\",\n  \"orgRole\": \"admin\",\n  \"orgSlug\": \"my-org\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has userId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('userId');",
                  "});",
                  "",
                  "pm.test('Response has sessionId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('sessionId');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Datasets",
      "item": [
        {
          "name": "Get Table Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/datasets/{{dataset_id}}/tables/{{table_id}}",
              "host": ["{{base_url}}"],
              "path": ["datasets", "{{dataset_id}}", "tables", "{{table_id}}"]
            },
            "description": "Protected endpoint - Returns detailed information for a specific BigQuery table.\n\nPath variables:\n- dataset_id: The BigQuery dataset ID (e.g. shopify_raw)\n- table_id: The BigQuery table ID (e.g. orders)\n\nResponse includes:\n- tableId, datasetId, type (TABLE | VIEW)\n- description\n- schema: array of fields with name, type, mode, description, nested fields\n- rowCount, sizeBytes\n- createdAt, lastModifiedAt (ISO 8601)\n- location (e.g. US)\n- partitioning (optional): type, field, requireFilter\n- clustering (optional): fields array\n- viewQuery (optional, VIEW type only)\n\nRequires a valid Clerk Bearer token with an active organization."
          },
          "response": [
            {
              "name": "Success - TABLE",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"tableId\": \"orders\",\n    \"datasetId\": \"shopify_raw\",\n    \"type\": \"TABLE\",\n    \"description\": \"Raw Shopify orders\",\n    \"schema\": [\n      { \"name\": \"id\", \"type\": \"INTEGER\", \"mode\": \"REQUIRED\", \"description\": \"Order ID\" },\n      { \"name\": \"customer_id\", \"type\": \"INTEGER\", \"mode\": \"NULLABLE\", \"description\": null },\n      { \"name\": \"total_price\", \"type\": \"FLOAT\", \"mode\": \"NULLABLE\", \"description\": null },\n      { \"name\": \"created_at\", \"type\": \"TIMESTAMP\", \"mode\": \"NULLABLE\", \"description\": null },\n      { \"name\": \"tags\", \"type\": \"STRING\", \"mode\": \"REPEATED\", \"description\": null }\n    ],\n    \"rowCount\": 12345,\n    \"sizeBytes\": 67890,\n    \"createdAt\": \"2024-01-01T00:00:00.000Z\",\n    \"lastModifiedAt\": \"2024-06-01T12:00:00.000Z\",\n    \"location\": \"US\",\n    \"partitioning\": { \"type\": \"DAY\", \"field\": \"created_at\", \"requireFilter\": false },\n    \"clustering\": { \"fields\": [\"customer_id\"] },\n    \"viewQuery\": null\n  },\n  \"statusCode\": 200\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "Success - VIEW",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"tableId\": \"daily_summary\",\n    \"datasetId\": \"shopify_raw\",\n    \"type\": \"VIEW\",\n    \"description\": \"Daily order totals\",\n    \"schema\": [\n      { \"name\": \"date\", \"type\": \"DATE\", \"mode\": \"NULLABLE\", \"description\": null },\n      { \"name\": \"total_revenue\", \"type\": \"FLOAT\", \"mode\": \"NULLABLE\", \"description\": null }\n    ],\n    \"rowCount\": null,\n    \"sizeBytes\": null,\n    \"createdAt\": \"2024-03-01T00:00:00.000Z\",\n    \"lastModifiedAt\": \"2024-06-01T12:00:00.000Z\",\n    \"location\": \"US\",\n    \"partitioning\": null,\n    \"clustering\": null,\n    \"viewQuery\": \"SELECT DATE(created_at) as date, SUM(total_price) as total_revenue FROM shopify_raw.orders GROUP BY 1\"\n  },\n  \"statusCode\": 200\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"statusCode\": 404,\n  \"message\": \"Organization not found\",\n  \"timestamp\": \"2024-06-01T12:00:00.000Z\",\n  \"path\": \"/api/datasets/shopify_raw/tables/orders\"\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "GCP Not Active",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"statusCode\": 403,\n  \"message\": \"Organization GCP project is not active (status: creating)\",\n  \"timestamp\": \"2024-06-01T12:00:00.000Z\",\n  \"path\": \"/api/datasets/shopify_raw/tables/orders\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data object', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('Table has required fields', function () {",
                  "    var table = pm.response.json().data;",
                  "    pm.expect(table).to.have.property('tableId');",
                  "    pm.expect(table).to.have.property('datasetId');",
                  "    pm.expect(table).to.have.property('type');",
                  "    pm.expect(table).to.have.property('schema');",
                  "    pm.expect(table.schema).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('tableId matches path variable', function () {",
                  "    var table = pm.response.json().data;",
                  "    pm.expect(table.tableId).to.eql(pm.variables.get('table_id'));",
                  "});",
                  "",
                  "pm.test('datasetId matches path variable', function () {",
                  "    var table = pm.response.json().data;",
                  "    pm.expect(table.datasetId).to.eql(pm.variables.get('dataset_id'));",
                  "});",
                  "",
                  "pm.test('Each schema field has name, type and mode', function () {",
                  "    var table = pm.response.json().data;",
                  "    table.schema.forEach(function (field) {",
                  "        pm.expect(field).to.have.property('name');",
                  "        pm.expect(field).to.have.property('type');",
                  "        pm.expect(field).to.have.property('mode');",
                  "    });",
                  "});",
                  "",
                  "pm.test('type is TABLE or VIEW', function () {",
                  "    var table = pm.response.json().data;",
                  "    pm.expect(['TABLE', 'VIEW', 'EXTERNAL', 'MATERIALIZED_VIEW']).to.include(table.type);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Datasets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/datasets",
              "host": ["{{base_url}}"],
              "path": ["datasets"]
            },
            "description": "Protected endpoint - Returns all BigQuery datasets and their tables for the authenticated user's organization.\n\nRequires a valid Clerk Bearer token with an active organization.\nThe organization's GCP project must be in 'active' status."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [\n    {\n      \"datasetId\": \"shopify_raw\",\n      \"tables\": [\n        { \"tableId\": \"orders\", \"type\": \"TABLE\" },\n        { \"tableId\": \"customers\", \"type\": \"TABLE\" }\n      ]\n    },\n    {\n      \"datasetId\": \"stripe_raw\",\n      \"tables\": [\n        { \"tableId\": \"payments\", \"type\": \"TABLE\" },\n        { \"tableId\": \"daily_summary\", \"type\": \"VIEW\" }\n      ]\n    }\n  ],\n  \"statusCode\": 200\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response data is an array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each dataset has datasetId and tables', function () {",
                  "    var jsonData = pm.response.json();",
                  "    jsonData.data.forEach(function (dataset) {",
                  "        pm.expect(dataset).to.have.property('datasetId');",
                  "        pm.expect(dataset).to.have.property('tables');",
                  "        pm.expect(dataset.tables).to.be.an('array');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Each table has tableId and type', function () {",
                  "    var jsonData = pm.response.json();",
                  "    jsonData.data.forEach(function (dataset) {",
                  "        dataset.tables.forEach(function (table) {",
                  "            pm.expect(table).to.have.property('tableId');",
                  "            pm.expect(table).to.have.property('type');",
                  "        });",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Clerk Webhook",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "svix-id",
                "value": "{{svix_id}}",
                "description": "Svix webhook ID"
              },
              {
                "key": "svix-timestamp",
                "value": "{{svix_timestamp}}",
                "description": "Svix webhook timestamp"
              },
              {
                "key": "svix-signature",
                "value": "{{svix_signature}}",
                "description": "Svix webhook signature"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"organization.created\",\n  \"data\": {\n    \"id\": \"org_2abc123\",\n    \"name\": \"My Organization\",\n    \"slug\": \"my-org\",\n    \"created_at\": 1700000000000\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/webhooks/clerk",
              "host": ["{{base_url}}"],
              "path": ["webhooks", "clerk"]
            },
            "description": "Public endpoint - Receives Clerk webhook events.\n\nSupported events:\n- organization.created: Provisions a new organization\n- organization.deleted: Deprovisions an organization\n\nRequires valid Svix headers for webhook signature verification."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success true', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
